<?xml version="1.0" encoding="utf-8"?>
<!--
  Nunito font family — bundled .ttf weights (no Downloadable Fonts / Play Services needed).
  @font/nunito is referenced by the XML theme (Theme.Yume) and preloaded_fonts.xml.
  Jetpack Compose uses the individual weights directly via Type.kt (R.font.nunito_*).
-->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto">
    <font app:fontStyle="normal" app:fontWeight="400" app:font="@font/nunito_regular" />
    <font app:fontStyle="normal" app:fontWeight="500" app:font="@font/nunito_medium" />
    <font app:fontStyle="normal" app:fontWeight="600" app:font="@font/nunito_semibold" />
    <font app:fontStyle="normal" app:fontWeight="700" app:font="@font/nunito_bold" />
    <font app:fontStyle="normal" app:fontWeight="800" app:font="@font/nunito_extrabold" />
    <font app:fontStyle="normal" app:fontWeight="900" app:font="@font/nunito_black" />
</font-family>
