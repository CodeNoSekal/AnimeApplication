<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher foreground — crescent in the 72dp safe zone.
     The bite is filled with the background tile color (#171A2A) so it
     composites seamlessly over ic_launcher_background.xml. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- moon (accent gradient) -->
    <path android:pathData="M28,53 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:startX="28" android:startY="27" android:endX="80" android:endY="79"
                android:type="linear">
                <item android:offset="0" android:color="#FF8A88FF" />
                <item android:offset="1" android:color="#FF6E6CFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- bite (background tile color) -->
    <path android:pathData="M42,44 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0 Z"
        android:fillColor="#171A2A" />

    <!-- star -->
    <path android:pathData="M40,33 m-1.8,0 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0 Z" android:fillColor="#A78BFA" />
</vector>
